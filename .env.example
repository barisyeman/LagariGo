# LagariGo Configuration

APP_NAME=LagariGo
APP_PORT=3000
APP_ENV=development
APP_URL=http://localhost:3000

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# Database driver: sqlite | mysql
DB_DRIVER=mysql

# SQLite (used when DB_DRIVER=sqlite)
DB_SQLITE_PATH=./lagarigo.db

# MySQL (used when DB_DRIVER=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lagarigo

# Default admin (created on first run if no users exist)
ADMIN_EMAIL=admin@lagarigo.local
ADMIN_PASSWORD=admin123
